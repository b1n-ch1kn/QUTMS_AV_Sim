<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- 
    ROS 2 Control Integration for Physics-Based Vehicle Control
    
    This configuration uses gz_ros2_control to control the vehicle using physics-based
    actuators instead of kinematic control (WorldPoseCmd).
    
    COMMAND + STATE INTERFACES:
    - Steering joints: position command (target steering angle)
    - Wheel joints: velocity + effort commands (supports both velocity and torque control)
    - State interfaces: position and velocity feedback for all joints
    - gz_ros2_control bridges commands from ROS 2 controllers to Gazebo actuators
    - Physics engine computes realistic vehicle motion from tire forces
    
    This enables:
    - Ackermann steering controller (velocity-based bicycle model)
    - Direct effort controllers (torque-based control)
    - Realistic tire slip and traction behavior
    - Proper weight transfer and suspension effects
    - More accurate simulation for control algorithm development
  -->

  <xacro:arg name="namespace" default="sim"/>

  <!-- ROS 2 Control System Definition -->
  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    
    <!-- Steering joints - position control for steering angle -->
    <joint name="left_steering_hinge_joint">
      <command_interface name="position">
        <param name="min">-0.6</param>  <!-- ~34 degrees -->
        <param name="max">0.6</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
    <joint name="right_steering_hinge_joint">
      <command_interface name="position">
        <param name="min">-0.6</param>
        <param name="max">0.6</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
    
    <!-- Wheel joints - velocity + effort control for flexibility -->
    <joint name="front_left_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-50</param>  <!-- rad/s - adjust based on vehicle specs -->
        <param name="max">50</param>
      </command_interface>
      <command_interface name="effort">
        <param name="min">-100</param>  <!-- Nm - adjust based on vehicle specs -->
        <param name="max">100</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
    <joint name="front_right_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-50</param>
        <param name="max">50</param>
      </command_interface>
      <command_interface name="effort">
        <param name="min">-100</param>
        <param name="max">100</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
    <joint name="rear_left_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-50</param>
        <param name="max">50</param>
      </command_interface>
      <command_interface name="effort">
        <param name="min">-100</param>
        <param name="max">100</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
    <joint name="rear_right_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-50</param>
        <param name="max">50</param>
      </command_interface>
      <command_interface name="effort">
        <param name="min">-100</param>
        <param name="max">100</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
  </ros2_control>

</robot>
